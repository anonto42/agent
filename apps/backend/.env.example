# Copy to .env for local dev. Loaded via the environment (Viper AutomaticEnv).
ENV=development
PORT=8080
LOG_LEVEL=info

DATABASE_URL=postgres://charli:charli@localhost:5432/charli?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# LLM (OpenAI-compatible). Defaults below target Google Gemini's free tier.
# Get a free key: https://aistudio.google.com/apikey
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gemini-2.0-flash
LLM_API_KEY=

# Swap providers by changing the three vars above, e.g.:
#   Groq:   LLM_BASE_URL=https://api.groq.com/openai/v1        LLM_MODEL=llama-3.3-70b-versatile
#   Ollama: LLM_BASE_URL=http://localhost:11434/v1             LLM_MODEL=qwen2.5:3b   (key can be anything)
