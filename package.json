{
  "name": "charli",
  "version": "0.0.0",
  "private": true,
  "description": "Charli — a flexible browser agent (Go backend + WXT extension + Next.js console).",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,yaml,yml}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "overrides": {
      "@vitejs/plugin-react": "^4.3.4",
      "vite": "6.4.3"
    }
  }
}
